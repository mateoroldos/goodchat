{
  "name": "goodchat",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "examples/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4"
    }
  },
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "dev": "turbo dev",
    "dev:apps": "turbo dev --filter=./apps/*",
    "dev:packages": "turbo dev --filter=./packages/*",
    "dev:examples": "turbo dev --filter=./examples/*",
    "build": "turbo build && node ./scripts/copy-web-assets.mjs",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:create": "bun run --cwd apps/create-cli dev:run",
    "check": "ultracite check",
    "check:knip": "bunx --bun knip",
    "check:all": "bun run check && bun run check-types && bun run check:knip",
    "ci:version": "changeset version && node ./scripts/update-create-cli-versions.mjs && bun update",
    "ci:publish": "for dir in packages/* apps/create-cli apps/goodchat-cli; do (cd \"$dir\" && bun publish || true); done && changeset tag",
    "fix": "ultracite fix",
    "release": "bun run build && bun run ci:publish",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:integration:sqlite": "bun test packages/storage/tests/sqlite/integration",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:migrations": "bunx turbo build --filter=@goodchat/core && node scripts/check-test-migrations.mjs",
    "test:migrations:update": "bunx turbo build --filter=@goodchat/core && bunx drizzle-kit generate --schema packages/storage/tests/postgres/schema.ts --out packages/storage/tests/postgres/drizzle --dialect postgresql && bunx drizzle-kit generate --schema packages/storage/tests/mysql/schema.ts --out packages/storage/tests/mysql/drizzle --dialect mysql && bunx drizzle-kit generate --schema packages/storage/tests/sqlite/schema.ts --out packages/storage/tests/sqlite/drizzle --dialect sqlite",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "@goodchat/typescript-config": "workspace:*",
    "@types/bun": "^1.3.12",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "lefthook": "latest",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "ultracite": "7.2.4",
    "vitest": "^4.1.4"
  },
  "packageManager": "bun@1.3.4"
}
