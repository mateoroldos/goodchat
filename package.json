{
  "name": "goodchat",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only"
  },
  "dependencies": {
    "@goodchat/env": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@goodchat/config": "workspace:*",
    "@types/bun": "^1.3.9",
    "lefthook": "latest",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "ultracite": "7.2.4"
  },
  "packageManager": "bun@1.3.4"
}
