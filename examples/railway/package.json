{
  "name": "nico",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "check-types": "tsc -b",
    "db:schema:sync": "goodchat db schema sync",
    "db:schema:check": "goodchat db schema sync --check",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "build": "tsdown",
    "start": "bun run dist/index.mjs",
    "start:railway": "bun run db:migrate && bun run start",
    "railway:link": "bunx @railway/cli link",
    "railway:up": "bunx @railway/cli up",
    "railway:logs": "bunx @railway/cli logs",
    "railway:migrate": "bunx @railway/cli run bun run db:migrate"
  },
  "dependencies": {
    "@goodchat/cli": "^0.0.13",
    "@goodchat/core": "^0.0.19",
    "@goodchat/storage": "^0.0.19",
    "@t3-oss/env-core": "^0.13.1",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.16.5",
    "typescript": "^5.9.3"
  }
}
