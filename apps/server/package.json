{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@goodbot/core": "workspace:*",
    "@t3-oss/env-core": "^0.13.1",
    "dotenv": "catalog:",
    "elysia": "^1.4.21",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@goodbot/config": "workspace:*",
    "@goodbot/plugins": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  }
}
