{
  "name": "server",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "db:schema:sync": "goodchat db schema sync",
    "db:schema:check": "goodchat db schema sync --check",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts"
  },
  "dependencies": {
    "@goodchat/adapter-sqlite": "workspace:*",
    "@goodchat/core": "workspace:*",
    "@goodchat/plugins": "workspace:*",
    "@libsql/client": "^0.17.2",
    "@t3-oss/env-core": "^0.13.1",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.21",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@goodchat/contracts": "workspace:*",
    "@goodchat/typescript-config": "workspace:*",
    "@goodchat/cli": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  }
}
