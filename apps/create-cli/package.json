{
  "name": "@goodchat/create",
  "version": "0.0.24",
  "private": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-goodchat": "dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:run": "bun run src/index.ts",
    "check-types": "tsc -b",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@goodchat/storage": "workspace:*",
    "figlet": "^1.11.0",
    "nanoid": "^5.1.9"
  },
  "devDependencies": {
    "@goodchat/contracts": "workspace:*",
    "@goodchat/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.4",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
