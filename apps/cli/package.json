{
  "name": "create-goodbot",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-goodbot": "dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:run": "bun run src/index.ts",
    "check-types": "tsc -b",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@goodbot/contracts": "workspace:*",
    "@goodbot/core": "workspace:*",
    "@goodbot/plugins": "workspace:*"
  },
  "devDependencies": {
    "@goodbot/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.4",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
