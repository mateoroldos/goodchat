---
import {
  siGithub,
  siJira,
  siLinear,
  siNotion,
  siSlack,
  siStripe,
} from "simple-icons";

const plugins = [
  {
    name: "GitHub",
    package: "@goodchat/plugin-github",
    description:
      "List open PRs, check issue statuses, review comments — all from chat.",
    icon: siGithub,
    tools: ["listOpenPRs", "getIssue", "createComment", "reviewPR"],
  },
  {
    name: "Linear",
    package: "@goodchat/plugin-linear",
    description:
      "Check sprint progress, create tickets, and update issue statuses in seconds.",
    icon: siLinear,
    tools: ["getIssues", "createIssue", "updateStatus", "getSprintProgress"],
  },
  {
    name: "Stripe",
    package: "@goodchat/plugin-stripe",
    description:
      "Look up subscriptions, check MRR, and handle billing questions from Slack.",
    icon: siStripe,
    tools: ["getSubscription", "lookupCustomer", "getMRR", "checkPayment"],
  },
  {
    name: "Notion",
    package: "@goodchat/plugin-notion",
    description:
      "Query databases, search pages, and keep your team aligned with Notion context.",
    icon: siNotion,
    tools: ["searchPages", "queryDatabase", "getPage", "createPage"],
  },
  {
    name: "Jira",
    package: "@goodchat/plugin-jira",
    description:
      "Sprint boards, ticket status, and blockers — surfaced right where your team talks.",
    icon: siJira,
    tools: ["getTicket", "listSprint", "createIssue", "getBlockers"],
  },
  {
    name: "Slack",
    package: "@goodchat/plugin-slack",
    description:
      "Post announcements, search message history, and react to events programmatically.",
    icon: siSlack,
    tools: ["postMessage", "searchHistory", "getUserInfo", "setStatus"],
  },
];
---

<section id="plugins" class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10">
      <h2
        class="text-2xl font-medium tracking-tight text-foreground sm:text-3xl"
      >
        Plugin ecosystem
      </h2>
      <p class="mt-2 text-sm text-muted-foreground max-w-xl">
        Install a plugin and your bot instantly speaks GitHub, Linear, or Stripe
        — no wiring needed.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
      {plugins.map((plugin) => (
        <div class="group border border-border/40 bg-surface-1 p-5 transition-colors duration-150 hover:bg-surface-2">
          <div class="mb-4 flex items-start justify-between gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-sm bg-foreground/5">
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                class="text-muted-foreground group-hover:text-foreground transition-colors duration-150"
              >
                <path d={plugin.icon.path} />
              </svg>
            </div>
            <code class="rounded-sm border border-border/40 bg-surface-2 px-2 py-0.5 font-mono text-[10px] text-muted-foreground">
              {plugin.package}
            </code>
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{plugin.name}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed mb-3">{plugin.description}</p>
          <div class="flex flex-wrap gap-1">
            {plugin.tools.map((tool) => (
              <span class="rounded-sm border border-border/40 bg-surface-2 px-1.5 py-0.5 font-mono text-[9px] text-muted-foreground">
                {tool}()
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-6 border border-dashed border-border/40 p-6 text-center">
      <p class="text-xs text-muted-foreground">
        Need something custom? Plugins are just functions.
        <a
          href="https://github.com/emestudio/goodchat"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 font-medium text-primary transition-opacity hover:opacity-80"
          >Use <code class="font-mono">definePlugin()</code> →</a
        >
      </p>
    </div>
  </div>
</section>
