    tools: ["postMessage", "searchHistory", "getUserInfo", "setStatus"],
  },
];
---

<section id="plugins" class="relative px-6 py-24">
  <!-- Subtle divider line -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
  ></div>

  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="mb-16 text-center">
      <p
        class="mb-3 text-sm font-medium uppercase tracking-widest text-primary"
      >
        Ecosystem
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Plugins that work on day one
      </h2>
      <p class="mt-4 max-w-xl mx-auto text-muted-foreground">
        Install a plugin and your bot instantly speaks GitHub, Linear, or Stripe
        — no wiring needed.
      </p>
    </div>

    <!-- Plugin grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {plugins.map((plugin) => (
          <div class="feature-card group rounded-2xl border border-white/6 bg-surface-1 p-5">
            <div class="mb-4 flex items-start justify-between">
              <div
                class="flex h-10 w-10 items-center justify-center rounded-xl"
                style={`background: ${plugin.bg}; color: ${plugin.color};`}
                set:html={plugin.icon}
              />
              <code class="rounded-lg border border-white/5 bg-surface-2 px-2.5 py-1 text-[11px] text-muted-foreground font-mono">
                {plugin.package}
              </code>
            </div>
            <h3 class="mb-1.5 text-sm font-semibold text-foreground">{plugin.name}</h3>
            <p class="mb-4 text-xs leading-relaxed text-muted-foreground">{plugin.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {plugin.tools.map((tool) => (
                <span
                  class="rounded-full border border-white/5 bg-surface-2 px-2 py-0.5 text-[10px] font-mono text-muted-foreground"
                >
                  {tool}()
                </span>
              ))}
            </div>
          </div>
        ))}
    </div>

    <!-- Write your own -->
    <div
      class="mt-8 rounded-2xl border border-dashed border-white/10 bg-surface-1/50 p-8 text-center"
    >
      <p class="text-sm font-medium text-foreground">Need something custom?</p>
      <p class="mt-1 text-sm text-muted-foreground">
        Plugins are just functions. Write your own with
        <code
          class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-xs text-primary"
          >definePlugin()</code
        >
        and share it with the community.
      </p>
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-primary transition-opacity hover:opacity-80"
      >
        Write a plugin →
      </a>
    </div>
  </div>
</section>
