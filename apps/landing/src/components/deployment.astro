---
const options = [
  {
    name: "Vercel",
    tagline: "Zero config. Deploy in 30 seconds.",
    description:
      "Push to GitHub and Vercel deploys automatically. Serverless functions handle all your webhook traffic.",
    badge: "Recommended",
    badgeColor: "oklch(0.78 0.185 70)",
    badgeBg: "oklch(0.78 0.185 70 / 12%)",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 22.525H0l12-21.05 12 21.05z"/></svg>`,
    iconColor: "oklch(0.97 0 0)",
    iconBg: "oklch(0.18 0 0)",
    steps: [{ cmd: "goodchat deploy", note: "auto-detects Vercel" }],
    pill: "Serverless",
  },
  {
    name: "Railway",
    tagline: "Docker-based. One-click from GitHub.",
    description:
      "Point Railway at the Dockerfile in the repo root. Set your env vars and Railway handles the rest.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M.187 13.637C.187 9.02 3.946 5.26 8.564 5.26c.587 0 1.163.062 1.717.18L8.95 7.45a6.25 6.25 0 0 0-.386-.025c-3.39 0-6.142 2.752-6.142 6.143 0 1.43.488 2.745 1.298 3.779a6.145 6.145 0 0 0 4.844 2.364c2.63 0 4.88-1.656 5.79-3.978h2.305C15.722 19.187 12.42 22 8.486 22A8.47 8.47 0 0 1 .187 13.637zm6.887-8.378a8.47 8.47 0 0 1 8.3 6.858h-2.28a6.148 6.148 0 0 0-6.02-4.832v-2.026zm3.79 6.858h9.949c-.044-4.585-3.778-8.305-8.37-8.305-.202 0-.403.007-.603.02l-.976 2.047c3.208.383 5.694 3.072 5.694 6.352v-.114z"/></svg>`,
    iconColor: "oklch(0.72 0.18 30)",
    iconBg: "oklch(0.72 0.18 30 / 12%)",
    steps: [
      { cmd: "docker build -f apps/server/Dockerfile -t goodchat .", note: "" },
      { cmd: "# deploy image on Railway via Dockerfile mode", note: "" },
    ],
    pill: "Docker",
  },
  {
    name: "Cloudflare",
    tagline: "Edge-native. Global by default.",
    description:
      "Deploy to Cloudflare Workers for sub-50ms response times worldwide. Set SERVERLESS=true in your env.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16.501 15.167c.12-.4.076-.823-.122-1.166-.197-.344-.522-.584-.893-.65l-9.316-1.31a.282.282 0 0 1-.2-.14.278.278 0 0 1-.016-.245.28.28 0 0 1 .244-.173l9.38-.54a2.44 2.44 0 0 0 2.207-1.697l.455-1.461a.255.255 0 0 0-.012-.194A6.138 6.138 0 0 0 12.5 3.5 6.152 6.152 0 0 0 6.516 8.07a2.793 2.793 0 0 0-1.9.57 2.736 2.736 0 0 0-.983 1.755 2.97 2.97 0 0 0-2.133.96 2.956 2.956 0 0 0-.743 2.225A2.975 2.975 0 0 0 3.78 16.5H16.17a.28.28 0 0 0 .274-.218l.057-.115z"/></svg>`,
    iconColor: "oklch(0.72 0.18 50)",
    iconBg: "oklch(0.72 0.18 50 / 12%)",
    steps: [
      { cmd: "SERVERLESS=true goodchat build", note: "" },
      { cmd: "wrangler deploy", note: "Cloudflare Workers" },
    ],
    pill: "Edge",
  },
  {
    name: "Docker / VPS",
    tagline: "Full control. Your server, your rules.",
    description:
      "Self-host on any VPS with Docker Compose. No telemetry, no lock-in, full control of your data.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13.983 11.078h2.119a.186.186 0 0 0 .186-.185V9.006a.186.186 0 0 0-.186-.186h-2.119a.185.185 0 0 0-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 0 0 .186-.186V3.574a.186.186 0 0 0-.186-.185h-2.118a.185.185 0 0 0-.185.185v1.888c0 .102.082.185.185.185m0 2.716h2.118a.187.187 0 0 0 .186-.186V6.29a.186.186 0 0 0-.186-.185h-2.118a.185.185 0 0 0-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 0 0 .184-.186V6.29a.185.185 0 0 0-.185-.185H8.1a.185.185 0 0 0-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 0 0 .185-.186V6.29a.185.185 0 0 0-.185-.185H5.136a.186.186 0 0 0-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 0 0 .186-.185V9.006a.186.186 0 0 0-.186-.186h-2.118a.185.185 0 0 0-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 0 0 .184-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.185.185 0 0 0-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 0 0 .185-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.186.186 0 0 0-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.186.186 0 0 0 .184-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.185.185 0 0 0-.184.186v1.887c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.09-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 0 0-.75.748 11.376 11.376 0 0 0 .692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 0 0 3.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288Z"/></svg>`,
    iconColor: "oklch(0.62 0.18 220)",
    iconBg: "oklch(0.62 0.18 220 / 12%)",
    steps: [
      { cmd: "docker-compose up -d", note: "docker-compose.yml in repo root" },
    ],
    pill: "Self-host",
  },
];
---

<section id="deploy" class="relative px-6 py-24">
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"
  ></div>

  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p
        class="mb-3 text-sm font-medium uppercase tracking-widest text-primary"
      >
        Deployment
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Ship it wherever you run things
      </h2>
      <p class="mt-4 mx-auto max-w-xl text-muted-foreground">
        One codebase. Any infrastructure. From serverless edge to bare-metal
        Docker — goodchat adapts to your stack.
      </p>
    </div>

    <!-- Deploy options grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {options.map((opt, i) => (
        <div
          class="reveal deploy-card group relative rounded-2xl border border-white/6 bg-surface-1 p-6 transition-all duration-200 hover:border-white/12 hover:bg-surface-2"
          style={`--reveal-delay: ${i * 80}ms`}
        >
          <div class="mb-4 flex items-start justify-between gap-3">
            <div class="flex items-center gap-3">
              <div
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
                style={`background: ${opt.iconBg}; color: ${opt.iconColor};`}
                set:html={opt.icon}
              />
              <div>
                <p class="text-sm font-semibold text-foreground">{opt.name}</p>
                <p class="text-xs text-muted-foreground">{opt.tagline}</p>
              </div>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-1.5">
              <span
                class="rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide"
                style={`background: ${opt.badgeBg ?? opt.iconBg}; color: ${opt.badgeColor ?? opt.iconColor};`}
              >
                {opt.pill}
              </span>
              {opt.badge && (
                <span class="text-[10px] font-medium text-primary">★ {opt.badge}</span>
              )}
            </div>
          </div>
          <p class="mb-4 text-sm leading-relaxed text-muted-foreground">{opt.description}</p>
          <div class="space-y-2">
            {opt.steps.map((step) => (
              <div class="flex items-center gap-2 rounded-lg bg-surface-2 px-3 py-2.5 font-mono text-xs">
                <span class="shrink-0 text-muted-foreground/50">$</span>
                <span class="text-foreground">{step.cmd}</span>
                {step.note && (
                  <span class="ml-auto shrink-0 text-muted-foreground/50 text-[10px]">{step.note}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- env vars note -->
    <div
      class="reveal mt-8 rounded-2xl border border-white/6 bg-surface-1 p-6"
      style="--reveal-delay: 360ms"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
        <div
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary"
        >
          <svg
            aria-hidden="true"
            fill="none"
            height="18"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="18"
          >
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4M12 8h.01" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="mb-1 text-sm font-semibold text-foreground">
            Required env vars
          </p>
          <p class="mb-3 text-sm text-muted-foreground">
            All you need to get started. Platform credentials are optional — add
            them only for the platforms you connect.
          </p>
          <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {[
              { key: "OPENAI_API_KEY", note: "or ANTHROPIC_API_KEY" },
              { key: "SLACK_BOT_TOKEN", note: "optional · for Slack" },
              { key: "DISCORD_BOT_TOKEN", note: "optional · for Discord" },
              { key: "CORS_ORIGIN", note: "optional · if UI is on different origin" },
            ].map(({ key, note }) => (
              <div class="flex items-center gap-2 rounded-lg bg-surface-2 px-3 py-2">
                <code class="text-xs font-mono text-primary">{key}</code>
                <span class="ml-auto text-[10px] text-muted-foreground">{note}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Self-hosting CTA -->
    <div
      class="reveal mt-6 text-center text-sm text-muted-foreground"
      style="--reveal-delay: 440ms"
    >
      goodchat is fully self-hostable. You own your data, prompts, and
      infrastructure.
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-1 font-medium text-primary transition-opacity hover:opacity-80"
        >No telemetry. No vendor lock-in. →</a
      >
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const reveals = document.querySelectorAll("#deploy .reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
  );
  for (const el of reveals) {
    observer.observe(el);
  }
</script>
