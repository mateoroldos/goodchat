---
import { siCloudflare, siDocker, siRailway, siVercel } from "simple-icons";

const options = [
  {
    name: "Vercel",
    tagline: "Zero config. Deploy in 30 seconds.",
    description:
      "Push to GitHub and Vercel deploys automatically. Serverless functions handle all your webhook traffic.",
    badge: "Recommended",
    icon: siVercel,
    steps: [{ cmd: "goodchat deploy", note: "auto-detects Vercel" }],
    pill: "Serverless",
  },
  {
    name: "Railway",
    tagline: "Docker-based. One-click from GitHub.",
    description:
      "Point Railway at the Dockerfile in the repo root. Set your env vars and Railway handles the rest.",
    icon: siRailway,
    steps: [
      { cmd: "docker build -f apps/server/Dockerfile -t goodchat .", note: "" },
      { cmd: "# deploy via Railway Dockerfile mode", note: "" },
    ],
    pill: "Docker",
  },
  {
    name: "Cloudflare",
    tagline: "Edge-native. Global by default.",
    description:
      "Deploy to Cloudflare Workers for sub-50ms response times worldwide. Set SERVERLESS=true in your env.",
    icon: siCloudflare,
    steps: [
      { cmd: "SERVERLESS=true goodchat build", note: "" },
      { cmd: "wrangler deploy", note: "Cloudflare Workers" },
    ],
    pill: "Edge",
  },
  {
    name: "Docker / VPS",
    tagline: "Full control. Your server, your rules.",
    description:
      "Self-host on any VPS with Docker Compose. No telemetry, no lock-in, full control of your data.",
    icon: siDocker,
    steps: [
      { cmd: "docker-compose up -d", note: "docker-compose.yml in repo root" },
    ],
    pill: "Self-host",
  },
];
---

<section id="deploy" class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10">
      <h2
        class="text-2xl font-medium tracking-tight text-foreground sm:text-3xl"
      >
        Deploy anywhere
      </h2>
      <p class="mt-2 text-sm text-muted-foreground max-w-xl">
        One codebase. Any infrastructure. From serverless edge to bare-metal
        Docker — goodchat adapts to your stack.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
      {options.map((opt) => (
        <div class="group border border-border/40 bg-surface-1 p-5 transition-colors duration-150 hover:bg-surface-2">
          <div class="mb-3 flex items-start justify-between gap-3">
            <div class="flex items-center gap-3">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-sm bg-foreground/5">
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="currentColor"
                  class="text-muted-foreground group-hover:text-foreground transition-colors duration-150"
                >
                  <path d={opt.icon.path} />
                </svg>
              </div>
              <div>
                <p class="text-xs font-medium text-foreground">{opt.name}</p>
                <p class="text-[11px] text-muted-foreground">{opt.tagline}</p>
              </div>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-1">
              <span class="rounded-sm border border-border/40 px-2 py-0.5 font-mono text-[9px] text-muted-foreground uppercase tracking-wide">
                {opt.pill}
              </span>
              {opt.badge && (
                <span class="font-mono text-[9px] text-primary">★ {opt.badge}</span>
              )}
            </div>
          </div>
          <p class="mb-3 text-xs leading-relaxed text-muted-foreground">{opt.description}</p>
          <div class="space-y-1.5">
            {opt.steps.map((step) => (
              <div class="flex items-center gap-2 rounded-sm bg-surface-2 px-3 py-2 font-mono text-xs">
                <span class="shrink-0 text-muted-foreground/40">$</span>
                <span class="text-foreground">{step.cmd}</span>
                {step.note && (
                  <span class="ml-auto shrink-0 text-muted-foreground/40 text-[9px]">{step.note}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="mt-5 text-center text-xs text-muted-foreground">
      Fully self-hostable. You own your data, prompts, and infrastructure.
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-1 font-medium text-primary transition-opacity hover:opacity-80"
        >No telemetry. No vendor lock-in. →</a
      >
    </p>
  </div>
</section>
