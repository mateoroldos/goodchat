---
import { siGithub } from "simple-icons";
---

<section id="get-started-section" class="border-t border-border/40 px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-2xl font-medium tracking-tight text-foreground sm:text-3xl">
      Build your first bot
    </h2>
    <p class="mt-3 text-sm text-muted-foreground max-w-lg">
      Open source. Self-hostable. No vendor lock-in. You own your bots, your
      data, and your infrastructure.
    </p>

    <div class="mt-6 flex flex-wrap gap-3 text-xs text-muted-foreground">
      {[
        "TypeScript native",
        "Streaming by default",
        "Vercel AI SDK",
        "MIT licensed",
        "No telemetry",
      ].map((item) => (
        <div class="flex items-center gap-1.5">
          <svg aria-hidden="true" fill="none" height="11" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="11" class="text-primary">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>{item}</span>
        </div>
      ))}
    </div>

    <div
      class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center"
    >
      <div class="code-block flex items-center gap-3 px-4 py-2.5 text-xs">
        <span class="text-muted-foreground select-none font-mono">$</span>
        <span class="font-mono text-foreground">npm create @goodchat</span>
      </div>
      <span class="text-muted-foreground text-xs hidden sm:block">or</span>
      <div class="code-block flex items-center gap-3 px-4 py-2.5 text-xs">
        <span class="text-muted-foreground select-none font-mono">$</span>
        <span class="font-mono text-foreground">goodchat init my-bot</span>
      </div>
    </div>

    <div class="mt-7 flex items-center gap-4">
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-sm bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        <svg
          aria-hidden="true"
          fill="currentColor"
          height="14"
          viewBox="0 0 24 24"
          width="14"
        >
          <path d={siGithub.path} />
        </svg>
        Star on GitHub
      </a>
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        Read the docs →
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-border/40 px-6 py-8">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-4 sm:flex-row sm:items-center"
  >
    <div class="flex items-center gap-2">
      <svg
        aria-hidden="true"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          fill="var(--primary)"
          fill-rule="evenodd"
          d="M0 0 H24 V24 H0 Z M11 2 H13 V6 H11 Z M4 6 H20 V19 H4 Z M7 9 H10 V12 H7 Z M14 9 H17 V12 H14 Z M9 15 H15 V16.5 H9 Z"
        />
      </svg>
      <span class="text-sm font-medium text-foreground">goodchat</span>
      <span class="text-xs text-muted-foreground">— MIT License</span>
    </div>

    <div class="flex items-center gap-5 text-xs text-muted-foreground">
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
        >GitHub</a
      >
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
        >Docs</a
      >
      <a
        href="https://github.com/emestudio/goodchat/issues"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
        >Issues</a
      >
    </div>
  </div>
</footer>
