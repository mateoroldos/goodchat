---
import { siGithub } from "simple-icons";
---

<nav
  class="fixed top-0 z-50 w-full border-b border-border/40 bg-background/80 backdrop-blur-xl"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between py-4">
    <a href="/" class="flex items-center gap-2.5 group">
      <svg
        aria-hidden="true"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
        class="transition-opacity group-hover:opacity-75"
      >
        <path
          fill="var(--primary)"
          fill-rule="evenodd"
          d="M0 0H24V24H0Z M11 2H13V6H11Z M4 6H20V19H4Z M7 9H10V12H7Z M14 9H17V12H14Z M9 15H15V16.5H9Z"
        />
      </svg>
      <span class="text-sm font-medium tracking-tight text-foreground"
        >goodbot</span
      >
    </a>

    <div class="hidden items-center gap-6 md:flex">
      <a
        href="#features"
        class="text-xs text-muted-foreground transition-colors hover:text-foreground"
        >Features</a
      >
      <a
        href="#examples"
        class="text-xs text-muted-foreground transition-colors hover:text-foreground"
        >Examples</a
      >
      <a
        href="#plugins"
        class="text-xs text-muted-foreground transition-colors hover:text-foreground"
        >Plugins</a
      >
      <a
        href="#deploy"
        class="text-xs text-muted-foreground transition-colors hover:text-foreground"
        >Deploy</a
      >
    </div>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        aria-label="Toggle light/dark theme"
        class="flex h-7 w-7 items-center justify-center rounded-sm border border-border/40 text-muted-foreground transition-colors hover:text-foreground"
        type="button"
      >
        <svg
          class="theme-sun hidden"
          aria-hidden="true"
          fill="none"
          height="14"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          viewBox="0 0 24 24"
          width="14"
        >
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
        <svg
          class="theme-moon hidden"
          aria-hidden="true"
          fill="none"
          height="13"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          viewBox="0 0 24 24"
          width="13"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <a
        href="https://github.com/emestudio/goodbot"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-xs text-muted-foreground transition-colors hover:text-foreground"
      >
        <svg
          aria-hidden="true"
          fill="currentColor"
          height="15"
          viewBox="0 0 24 24"
          width="15"
        >
          <path d={siGithub.path} />
        </svg>
        <span class="hidden sm:block">GitHub</span>
      </a>
      <a
        href="#get-started-section"
        class="rounded-sm bg-primary px-3.5 py-1.5 text-xs font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        Get started
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("theme-toggle");
  const html = document.documentElement;
  const sun = document.querySelector(".theme-sun") as HTMLElement | null;
  const moon = document.querySelector(".theme-moon") as HTMLElement | null;

  function updateIcons() {
    const isDark = html.classList.contains("dark");
    if (sun) {
      sun.style.display = isDark ? "block" : "none";
    }
    if (moon) {
      moon.style.display = isDark ? "none" : "block";
    }
  }

  updateIcons();

  toggle?.addEventListener("click", () => {
    const isDark = html.classList.toggle("dark");
    localStorage.theme = isDark ? "dark" : "light";
    updateIcons();
  });
</script>
