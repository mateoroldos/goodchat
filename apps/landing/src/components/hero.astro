---
---

<section
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 pt-24 pb-20"
>
  <!-- Background gradients -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/3 rounded-full opacity-20"
      style="background: radial-gradient(ellipse, oklch(0.65 0.22 62) 0%, transparent 70%);"
    ></div>
    <div
      class="absolute left-1/4 bottom-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full opacity-10"
      style="background: radial-gradient(ellipse, oklch(0.60 0.20 46) 0%, transparent 70%);"
    ></div>
    <!-- Grid pattern -->
    <div
      class="absolute inset-0 opacity-[0.015]"
      style="background-image: linear-gradient(oklch(1 0 0) 1px, transparent 1px), linear-gradient(90deg, oklch(1 0 0) 1px, transparent 1px); background-size: 64px 64px;"
    ></div>
  </div>

  <div class="relative z-10 flex flex-col items-center text-center">
    <!-- Badge -->
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-xs font-medium text-primary"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"
        ></span>
        <span
          class="relative inline-flex h-2 w-2 rounded-full bg-primary"
        ></span>
      </span>
      Open source · Self-hostable · TypeScript native
    </div>

    <!-- Headline -->
    <h1
      class="max-w-4xl text-5xl font-bold tracking-tight text-foreground sm:text-6xl md:text-7xl"
    >
      One bot.
      <span class="gradient-text"> Every platform.</span>
    </h1>

    <!-- Sub-headline -->
    <p class="mt-6 max-w-2xl text-lg text-muted-foreground sm:text-xl">
      Build AI-powered chatbots for Slack, Discord, Teams, and Google Chat —
      <br class="hidden sm:block">
      from a single config. No webhook juggling. No adapter hell.
    </p>

    <!-- Platform badges -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <!-- Slack -->
      <div
        class="flex items-center gap-2 rounded-full border border-white/8 bg-white/4 px-4 py-2 text-sm font-medium text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          fill="none"
          height="16"
          viewBox="0 0 24 24"
          width="16"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zm2.521-10.123a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zm10.122 2.521a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.268 0a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zm-2.523 10.122a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.268a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"
            fill="#E01E5A"
          />
        </svg>
        Slack
      </div>
      <!-- Discord -->
      <div
        class="flex items-center gap-2 rounded-full border border-white/8 bg-white/4 px-4 py-2 text-sm font-medium text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          fill="#5865F2"
          height="16"
          viewBox="0 0 24 24"
          width="16"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.054a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
          />
        </svg>
        Discord
      </div>
      <!-- Teams -->
      <div
        class="flex items-center gap-2 rounded-full border border-white/8 bg-white/4 px-4 py-2 text-sm font-medium text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          fill="none"
          height="16"
          viewBox="0 0 24 24"
          width="16"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M20.625 6.75H15v7.125a3.375 3.375 0 1 1-6.75 0V6.75H3.375A.375.375 0 0 0 3 7.125v9.75c0 .207.168.375.375.375h17.25a.375.375 0 0 0 .375-.375v-9.75a.375.375 0 0 0-.375-.375z"
            fill="#5558AF"
          />
          <circle cx="15.75" cy="4.125" r="2.625" fill="#5558AF" />
          <circle cx="8.25" cy="9.375" r="2.625" fill="#7B83EB" />
          <path
            d="M11.625 12H4.875A.375.375 0 0 0 4.5 12.375v4.5c0 .207.168.375.375.375h1.5v1.875c0 .207.168.375.375.375h3a.375.375 0 0 0 .375-.375V17.25h1.5a.375.375 0 0 0 .375-.375v-4.5A.375.375 0 0 0 11.625 12z"
            fill="#7B83EB"
          />
        </svg>
        Teams
      </div>
      <!-- Google Chat -->
      <div
        class="flex items-center gap-2 rounded-full border border-white/8 bg-white/4 px-4 py-2 text-sm font-medium text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          fill="none"
          height="16"
          viewBox="0 0 24 24"
          width="16"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"
            fill="#00AC47"
          />
          <path
            d="M12 2C6.48 2 2 6.48 2 12c0 2.93 1.26 5.57 3.27 7.43L12 22l6.73-2.57A9.955 9.955 0 0 0 22 12c0-5.52-4.48-10-10-10z"
            fill="#00AC47"
            opacity=".5"
          />
          <path
            d="M16.5 8.5c0 .83-.67 1.5-1.5 1.5s-1.5-.67-1.5-1.5S14.17 7 15 7s1.5.67 1.5 1.5zM11 8.5C11 9.33 10.33 10 9.5 10S8 9.33 8 8.5 8.67 7 9.5 7 11 7.67 11 8.5z"
            fill="white"
          />
        </svg>
        Google Chat
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row">
      <a
        id="get-started"
        href="#get-started-section"
        class="group flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-all hover:opacity-90 hover:shadow-lg"
        style="box-shadow: 0 0 0 0 oklch(0.78 0.185 70 / 40%);"
      >
        Get started free
        <svg
          aria-hidden="true"
          class="transition-transform group-hover:translate-x-0.5"
          fill="none"
          height="16"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="16"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-xl border border-white/10 bg-white/4 px-6 py-3 text-sm font-medium text-foreground transition-all hover:bg-white/8 hover:border-white/15"
      >
        <svg
          aria-hidden="true"
          fill="currentColor"
          height="16"
          viewBox="0 0 24 24"
          width="16"
        >
          <path
            d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12c0-5.523-4.477-10-10-10Z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Quick install -->
    <div class="mt-8">
      <div class="code-block inline-flex items-center gap-3 px-5 py-3 text-sm">
        <span class="text-muted-foreground select-none">$</span>
        <span class="text-foreground font-mono"
          >npx create-goodchat my-bot</span
        >
        <button
          id="copy-install"
          aria-label="Copy install command"
          class="ml-2 rounded p-1 text-muted-foreground transition-colors hover:text-foreground"
          title="Copy to clipboard"
          type="button"
        >
          <svg
            aria-hidden="true"
            fill="none"
            height="14"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="14"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path
              d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Floating demo preview -->
  <div class="relative z-10 mt-16 w-full max-w-4xl">
    <div
      class="rounded-2xl border border-white/8 bg-surface-1 shadow-2xl"
      style="box-shadow: 0 32px 64px oklch(0 0 0 / 50%), 0 0 0 1px oklch(1 0 0 / 5%);"
    >
      <!-- Window chrome -->
      <div class="flex items-center gap-2 border-b border-white/5 px-5 py-3">
        <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
        <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
        <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
        <div class="ml-4 flex items-center gap-2">
          <span class="text-xs text-muted-foreground font-mono"
            >apps/server/src/app.ts</span
          >
        </div>
      </div>
      <!-- Code preview -->
      <div
        class="code-block rounded-none rounded-b-2xl border-none text-sm leading-relaxed"
      >
        <pre
        ><code><span class="token-keyword">import</span> <span class="token-punctuation">&#123;</span> <span class="token-function">createGoodbot</span> <span class="token-punctuation">&#125;</span> <span class="token-keyword">from</span> <span class="token-string">"@goodchat/core"</span><span class="token-punctuation">;</span>
<span class="token-keyword">import</span> <span class="token-punctuation">&#123;</span> <span class="token-value">linear</span> <span class="token-punctuation">&#125;</span> <span class="token-keyword">from</span> <span class="token-string">"@goodchat/plugins/linear"</span><span class="token-punctuation">;</span>
<span class="token-keyword">import</span> <span class="token-punctuation">&#123;</span> <span class="token-value">github</span> <span class="token-punctuation">&#125;</span> <span class="token-keyword">from</span> <span class="token-string">"@goodchat/plugins/github"</span><span class="token-punctuation">;</span>

<span class="token-keyword">await</span> <span class="token-function">createGoodbot</span><span class="token-punctuation">(&#123;</span>
  <span class="token-property">name</span><span class="token-punctuation">:</span> <span class="token-string">"eng-bot"</span><span class="token-punctuation">,</span>
  <span class="token-property">prompt</span><span class="token-punctuation">:</span> <span class="token-string">"You are an AI assistant for our engineering team."</span><span class="token-punctuation">,</span>
  <span class="token-property">platforms</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span><span class="token-string">"slack"</span><span class="token-punctuation">,</span> <span class="token-string">"discord"</span><span class="token-punctuation">]</span><span class="token-punctuation">,</span>
  <span class="token-property">plugins</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span>
    <span class="token-function">linear</span><span class="token-punctuation">(&#123;</span> <span class="token-property">team</span><span class="token-punctuation">:</span> <span class="token-string">"ENG"</span> <span class="token-punctuation">&#125;)</span><span class="token-punctuation">,</span>
    <span class="token-function">github</span><span class="token-punctuation">(&#123;</span> <span class="token-property">repo</span><span class="token-punctuation">:</span> <span class="token-string">"acme/backend"</span> <span class="token-punctuation">&#125;)</span><span class="token-punctuation">,</span>
  <span class="token-punctuation">]</span><span class="token-punctuation">,</span>
<span class="token-punctuation">&#125;)</span><span class="token-punctuation">;</span></code></pre>
      </div>
    </div>
    <!-- Glow below card -->
    <div
      class="pointer-events-none absolute -bottom-20 left-1/2 h-40 w-3/4 -translate-x-1/2 rounded-full opacity-20 blur-3xl"
      style="background: oklch(0.65 0.22 62);"
    ></div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById("copy-install");
  copyBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText("npx create-goodchat my-bot");
    if (copyBtn instanceof HTMLElement) {
      copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      setTimeout(() => {
        copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
      }, 2000);
    }
  });
</script>
