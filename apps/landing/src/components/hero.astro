---
import { siDiscord, siGithub, siGooglechat, siSlack } from "simple-icons";
---

<section
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 pt-24 pb-20"
>
  <div class="relative z-10 flex flex-col items-center text-center">
    <div
      class="mb-8 inline-flex items-center gap-2 rounded-sm border border-border/40 px-3 py-1 font-mono text-[11px] text-muted-foreground"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      open source · self-hostable · typescript native
    </div>

    <h1
      class="max-w-3xl text-4xl font-medium tracking-tight text-foreground sm:text-5xl"
    >
      One bot. Every platform.
    </h1>

    <p class="mt-5 max-w-xl text-sm text-muted-foreground leading-relaxed">
      Build AI chatbots for Slack, Discord, Teams, and Google Chat from a single
      config. No webhook juggling. No adapter hell.
    </p>

    <div class="mt-7 flex flex-wrap items-center justify-center gap-2">
      <div
        class="flex items-center gap-1.5 rounded-sm border border-border/50 px-3 py-1.5 text-xs text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="currentColor"
        >
          <path d={siSlack.path} />
        </svg>
        Slack
      </div>
      <div
        class="flex items-center gap-1.5 rounded-sm border border-border/50 px-3 py-1.5 text-xs text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="currentColor"
        >
          <path d={siDiscord.path} />
        </svg>
        Discord
      </div>
      <div
        class="flex items-center gap-1.5 rounded-sm border border-border/50 px-3 py-1.5 text-xs text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="currentColor"
        >
          <path
            d="M19.5 3h-3.375a2.625 2.625 0 1 0-5.25 0H7.5A1.5 1.5 0 0 0 6 4.5v15A1.5 1.5 0 0 0 7.5 21h12a1.5 1.5 0 0 0 1.5-1.5v-15A1.5 1.5 0 0 0 19.5 3zm-7.5 0a1.125 1.125 0 1 1 2.25 0 1.125 1.125 0 0 1-2.25 0zm1.5 14.625L9 13.5l1.06-1.06 3.44 3.44 5.44-5.44L20 11.5l-6.5 6.125z"
          />
        </svg>
        Teams
      </div>
      <div
        class="flex items-center gap-1.5 rounded-sm border border-border/50 px-3 py-1.5 text-xs text-muted-foreground"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="currentColor"
        >
          <path d={siGooglechat.path} />
        </svg>
        Google Chat
      </div>
    </div>

    <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row">
      <a
        href="#get-started-section"
        class="flex items-center gap-2 rounded-sm bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        Get started
        <svg
          aria-hidden="true"
          fill="none"
          height="14"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="14"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
      <a
        href="https://github.com/emestudio/goodchat"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-sm border border-border/40 px-5 py-2.5 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
      >
        <svg
          aria-hidden="true"
          fill="currentColor"
          height="14"
          viewBox="0 0 24 24"
          width="14"
        >
          <path d={siGithub.path} />
        </svg>
        GitHub
      </a>
    </div>

    <div class="mt-7">
      <div
        class="code-block inline-flex items-center gap-3 px-4 py-2.5 text-xs"
      >
        <span class="text-muted-foreground select-none">$</span>
        <span class="text-foreground">npm create @goodchat</span>
        <button
          id="copy-install"
          aria-label="Copy install command"
          class="ml-1 rounded p-1 text-muted-foreground transition-colors hover:text-foreground"
          title="Copy to clipboard"
          type="button"
        >
          <svg
            aria-hidden="true"
            fill="none"
            height="12"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="12"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path
              d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="relative z-10 mt-14 w-full max-w-5xl">
    <div class="rounded-sm border border-border/40 bg-surface-1">
      <div
        class="flex items-center gap-2 border-b border-border/40 px-4 py-2.5"
      >
        <div class="h-2.5 w-2.5 rounded-full bg-destructive/50"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-chart-4/50"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-chart-2/50"></div>
        <span class="ml-3 font-mono text-xs text-muted-foreground"
          >goodchat.config.ts</span
        >
      </div>
      <div
        class="code-block rounded-none! border-none! text-xs leading-relaxed"
      >
        <pre
        ><code><span class="token-keyword">import</span> <span class="token-punctuation">&#123;</span> <span class="token-function">createGoodchat</span> <span class="token-punctuation">&#125;</span> <span class="token-keyword">from</span> <span class="token-string">"@goodchat/core"</span><span class="token-punctuation">;</span>
<span class="token-keyword">import</span> <span class="token-punctuation">&#123;</span> <span class="token-value">linear</span> <span class="token-punctuation">&#125;</span> <span class="token-keyword">from</span> <span class="token-string">"@goodchat/plugins/linear"</span><span class="token-punctuation">;</span>
<span class="token-keyword">import</span> <span class="token-punctuation">&#123;</span> <span class="token-value">github</span> <span class="token-punctuation">&#125;</span> <span class="token-keyword">from</span> <span class="token-string">"@goodchat/plugins/github"</span><span class="token-punctuation">;</span>

<span class="token-keyword">await</span> <span class="token-function">createGoodchat</span><span class="token-punctuation">(&#123;</span>
  <span class="token-property">name</span><span class="token-punctuation">:</span> <span class="token-string">"eng-bot"</span><span class="token-punctuation">,</span>
  <span class="token-property">prompt</span><span class="token-punctuation">:</span> <span class="token-string">"You are an AI assistant for our engineering team."</span><span class="token-punctuation">,</span>
  <span class="token-property">model</span><span class="token-punctuation">:</span> <span class="token-string">"openai/gpt-4.1-nano"</span><span class="token-punctuation">,</span>
  <span class="token-property">platforms</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span><span class="token-string">"slack"</span><span class="token-punctuation">,</span> <span class="token-string">"discord"</span><span class="token-punctuation">]</span><span class="token-punctuation">,</span>
  <span class="token-property">plugins</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span>
    <span class="token-function">linear</span><span class="token-punctuation">(&#123;</span> <span class="token-property">team</span><span class="token-punctuation">:</span> <span class="token-string">"ENG"</span> <span class="token-punctuation">&#125;)</span><span class="token-punctuation">,</span>
    <span class="token-function">github</span><span class="token-punctuation">(&#123;</span> <span class="token-property">repo</span><span class="token-punctuation">:</span> <span class="token-string">"acme/backend"</span> <span class="token-punctuation">&#125;)</span><span class="token-punctuation">,</span>
  <span class="token-punctuation">]</span><span class="token-punctuation">,</span>
<span class="token-punctuation">&#125;)</span><span class="token-punctuation">;</span></code></pre>
      </div>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById("copy-install");
  copyBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText("npm create @goodchat");
    if (copyBtn instanceof HTMLElement) {
      copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      setTimeout(() => {
        copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
      }, 2000);
    }
  });
</script>
