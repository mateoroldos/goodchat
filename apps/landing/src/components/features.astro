---
const features = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "One config. Every platform.",
    description:
      "Write your bot once. goodbot handles adapters, webhook routing, and message formatting for Slack, Discord, Teams, and Google Chat automatically.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "Streaming responses",
    description:
      "Responses stream in real time across every connected platform. Users see the bot typing progressively — no waiting for a complete reply.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>`,
    title: "Plugins — extend with one line",
    description:
      "Install a plugin and your bot instantly gains tools, context loaders, and event handlers. GitHub, Linear, Stripe — ready to use.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
    title: "Context & RAG",
    description:
      "Attach files, URLs, or folders. Your bot chunks, embeds, and retrieves context automatically — re-indexing whenever your sources change.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: "Tools — let your bot act",
    description:
      "Give your bot the ability to look things up, check statuses, or call your APIs in real time using the Vercel AI SDK tool interface.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Escalation — know when to hand off",
    description:
      "Define when the bot should stop and bring a human in. It gracefully hands off the conversation instead of guessing.",
  },
];
---

<section id="features" class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10">
      <h2
        class="text-2xl font-medium tracking-tight text-foreground sm:text-3xl"
      >
        What's included
      </h2>
      <p class="mt-2 text-sm text-muted-foreground max-w-lg">
        From streaming responses to plugin ecosystems — goodbot handles the hard
        parts so you focus on your bot's logic.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="group border border-border/40 bg-surface-1 p-5 transition-colors duration-150 hover:bg-surface-2">
          <div
            class="mb-3 text-muted-foreground group-hover:text-primary transition-colors duration-150"
            set:html={feature.icon}
          />
          <h3 class="text-sm font-semibold mb-1.5 text-foreground">{feature.title}</h3>
          <p class="leading-relaxed text-muted-foreground text-xs">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
