---
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "One config. Every platform.",
    description:
      "Write your bot once. goodchat handles adapters, webhook routing, and message formatting for Slack, Discord, Teams, and Google Chat automatically.",
    accent: "oklch(0.78 0.185 70)",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "Streaming responses",
    description:
      "Responses stream in real time across every connected platform. Users see the bot typing progressively — no waiting for a complete reply.",
    accent: "oklch(0.65 0.18 200)",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>`,
    title: "Plugins — extend with one line",
    description:
      "Install a plugin and your bot instantly gains tools, context loaders, and event handlers. GitHub, Linear, Stripe — ready to use.",
    accent: "oklch(0.70 0.18 140)",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
    title: "Context & RAG",
    description:
      "Attach files, URLs, or folders. Your bot chunks, embeds, and retrieves context automatically — re-indexing whenever your sources change.",
    accent: "oklch(0.68 0.2 30)",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: "Tools — let your bot act",
    description:
      "Give your bot the ability to look things up, check statuses, or call your APIs in real time using the Vercel AI SDK tool interface.",
    accent: "oklch(0.68 0.18 310)",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Escalation — know when to hand off",
    description:
      "Define when the bot should stop and bring a human in. It gracefully hands off the conversation instead of guessing.",
    accent: "oklch(0.68 0.18 60)",
  },
];
---

<section id="features" class="relative px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p
        class="mb-3 text-sm font-medium uppercase tracking-widest text-primary"
      >
        Features
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Everything you need to ship a great bot
      </h2>
      <p class="mt-4 text-muted-foreground max-w-xl mx-auto">
        From streaming responses to plugin ecosystems — goodchat handles the
        hard parts so you can focus on your bot's logic.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => (
          <div
            class="reveal feature-card group relative rounded-2xl border border-white/6 bg-surface-1 p-6"
            style={`--reveal-delay: ${i * 60}ms`}
          >
            <div
              class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl"
              style={`background: ${feature.accent}14; color: ${feature.accent};`}
              set:html={feature.icon}
            />
            <h3 class="mb-2 text-base font-semibold text-foreground">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{feature.description}</p>
          </div>
        ))}
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const reveals = document.querySelectorAll("#features .reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  for (const el of reveals) {
    observer.observe(el);
  }
</script>
