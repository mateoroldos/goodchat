            value: "#incident-2024-0322 war room thread",
          },
          {
            type: "footer",
            value: "Runbook: /runbooks/api-latency · Last incident: 18d ago",
          },
        ],
      },
      {
        from: "boss",
        avatar: "T",
        color: "green",
        name: "tom_h",
        time: "3:17 AM",
        text: "On it 🫡 — rolling back deploy from 3:02",
      },
    ],
    config: `<span class="token-keyword">await</span> <span class="token-function">createGoodbot</span><span class="token-punctuation">(&#123;</span>
  <span class="token-property">name</span><span class="token-punctuation">:</span> <span class="token-string">"incident-bot"</span><span class="token-punctuation">,</span>
  <span class="token-property">prompt</span><span class="token-punctuation">:</span> <span class="token-string">"You monitor for incidents and coordinate
  response. Be clear, fast, and calm."</span><span class="token-punctuation">,</span>
  <span class="token-property">platforms</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span><span class="token-string">"discord"</span><span class="token-punctuation">]</span><span class="token-punctuation">,</span>
  <span class="token-property">escalation</span><span class="token-punctuation">:</span> <span class="token-punctuation">&#123;</span>
    <span class="token-property">trigger</span><span class="token-punctuation">:</span> <span class="token-string">"any error rate spike or P0 alert"</span><span class="token-punctuation">,</span>
    <span class="token-property">action</span><span class="token-punctuation">:</span> <span class="token-punctuation">&#123;</span> <span class="token-property">type</span><span class="token-punctuation">:</span> <span class="token-string">"tag"</span><span class="token-punctuation">,</span> <span class="token-property">user</span><span class="token-punctuation">:</span> <span class="token-string">"@on-call-eng"</span> <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
  <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
  <span class="token-property">plugins</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span>
    <span class="token-function">linear</span><span class="token-punctuation">(&#123;</span> <span class="token-property">team</span><span class="token-punctuation">:</span> <span class="token-string">"SRE"</span> <span class="token-punctuation">&#125;)</span><span class="token-punctuation">,</span>
  <span class="token-punctuation">]</span><span class="token-punctuation">,</span>
  <span class="token-property">events</span><span class="token-punctuation">:</span> <span class="token-punctuation">&#123;</span>
    <span class="token-property">onMessage</span><span class="token-punctuation">:</span> <span class="token-keyword">async</span> <span class="token-punctuation">(&#123;</span> <span class="token-value">message</span><span class="token-punctuation">,</span> <span class="token-value">thread</span> <span class="token-punctuation">&#125;)</span> <span class="token-punctuation">=&gt;</span> <span class="token-punctuation">&#123;</span>
      <span class="token-keyword">if</span> <span class="token-punctuation">(</span><span class="token-value">message</span><span class="token-punctuation">.</span><span class="token-value">text</span><span class="token-punctuation">.</span><span class="token-function">includes</span><span class="token-punctuation">(</span><span class="token-string">"error rate"</span><span class="token-punctuation">))</span>
        <span class="token-keyword">await</span> <span class="token-value">thread</span><span class="token-punctuation">.</span><span class="token-function">respond</span><span class="token-punctuation">()</span><span class="token-punctuation">;</span>
    <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
  <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
<span class="token-punctuation">&#125;)</span><span class="token-punctuation">;</span>`,
  },
  {
    id: "onboarding",
    tabLabel: "handbook_bot.ts",
    tabIcon: siSlack,
    emoji: "🧭",
    label: "The new hire who reads zero docs",
    platform: "slack · #general",
    tagText: "Context + RAG",
    messages: [
      {
        from: "user",
        avatar: "J",
        color: "blue",
        name: "jake_new_hire",
        time: "10:03 AM",
        text: "hi! where's the design system? also what's the deploy process? oh and who do i bug for backend stuff",
      },
      {
        from: "bot",
        name: "handbook-bot",
        time: "10:03 AM",
        lines: [
          {
            type: "text",
            value: "Hey Jake! Great questions — here's the rundown:",
          },
          { type: "divider" },
          {
            type: "link",
            icon: "🎨",
            label: "Design system",
            value: "notion.acme.com/design → Figma tokens live here",
          },
          {
            type: "link",
            icon: "🚀",
            label: "Deploy process",
            value: "Push to main → CI runs → Vercel auto-deploys",
          },
          {
            type: "link",
            icon: "🙋",
            label: "Backend",
            value: "@sara is your person · also check #backend-help",
          },
          {
            type: "footer",
            value: "From: Engineering Handbook (updated 2d ago)",
          },
        ],
      },
      {
        from: "user",
        avatar: "J",
        color: "blue",
        name: "jake_new_hire",
        time: "10:04 AM",
        text: "wait this is way better than asking around 👀",
      },
      {
        from: "boss",
        avatar: "S",
        color: "purple",
        name: "sara",
        time: "10:05 AM",
        text: "lol the bot knows more than me at this point",
      },
    ],
    config: `<span class="token-keyword">await</span> <span class="token-function">createGoodbot</span><span class="token-punctuation">(&#123;</span>
  <span class="token-property">name</span><span class="token-punctuation">:</span> <span class="token-string">"handbook-bot"</span><span class="token-punctuation">,</span>
  <span class="token-property">prompt</span><span class="token-punctuation">:</span> <span class="token-string">"You are the team's internal assistant.
  Answer only from the provided context."</span><span class="token-punctuation">,</span>
  <span class="token-property">platforms</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span><span class="token-string">"slack"</span><span class="token-punctuation">]</span><span class="token-punctuation">,</span>
  <span class="token-property">context</span><span class="token-punctuation">:</span> <span class="token-punctuation">[</span>
    <span class="token-punctuation">&#123;</span> <span class="token-property">type</span><span class="token-punctuation">:</span> <span class="token-string">"url"</span><span class="token-punctuation">,</span> <span class="token-property">src</span><span class="token-punctuation">:</span> <span class="token-string">"notion.acme.com/handbook"</span> <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
    <span class="token-punctuation">&#123;</span> <span class="token-property">type</span><span class="token-punctuation">:</span> <span class="token-string">"folder"</span><span class="token-punctuation">,</span> <span class="token-property">src</span><span class="token-punctuation">:</span> <span class="token-string">"./docs/engineering"</span> <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
    <span class="token-punctuation">&#123;</span> <span class="token-property">type</span><span class="token-punctuation">:</span> <span class="token-string">"file"</span><span class="token-punctuation">,</span> <span class="token-property">src</span><span class="token-punctuation">:</span> <span class="token-string">"./team-directory.md"</span> <span class="token-punctuation">&#125;</span><span class="token-punctuation">,</span>
  <span class="token-punctuation">]</span><span class="token-punctuation">,</span>
<span class="token-punctuation">&#125;)</span><span class="token-punctuation">;</span>`,
  },
];

const avatarColors: Record<string, string> = {
  orange: "bg-chart-1/20 text-chart-1",
  red: "bg-destructive/20 text-destructive",
  blue: "bg-chart-3/20 text-chart-3",
  green: "bg-chart-2/20 text-chart-2",
  purple: "bg-chart-3/15 text-chart-3",
  primary: "bg-primary/20 text-primary",
};
---

<section id="examples" class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10">
      <h2
        class="text-2xl font-medium tracking-tight text-foreground sm:text-3xl"
      >
        Real-world examples
      </h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Click
        <span
          class="font-mono text-[11px] bg-surface-2 px-1.5 py-0.5 rounded-sm text-primary"
          >config</span
        >
        on any tab to see the code.
      </p>
    </div>

    <div class="border border-border/50 bg-surface-1">
      <div
        class="flex items-end gap-0.5 border-b border-border bg-surface-2 px-2 pt-1.5"
      >
        {examples.map((ex, i) => (
          <button
            class="relative top-px cursor-pointer whitespace-nowrap rounded-t-sm border border-b-0 border-border bg-surface-1 px-3 py-1 font-mono text-[11px] text-muted-foreground opacity-60 transition-opacity hover:opacity-90 data-[active]:z-10 data-[active]:border-b data-[active]:[border-bottom-color:var(--color-surface-1)] data-[active]:text-primary data-[active]:opacity-100"
            data-example-idx={i}
            data-active={i === 0 ? "" : undefined}
            type="button"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" width="10" height="10" fill="currentColor" class="mr-1 inline align-middle opacity-70">
              <path d={ex.tabIcon.path} />
            </svg>{ex.tabLabel}
          </button>
        ))}
        <div class="flex-1"></div>
      </div>

      {examples.map((ex, i) => (
        <div class={`example-panel ${i !== 0 ? "hidden" : ""}`} data-panel-idx={i}>
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border/40 px-4 py-3">
            <div>
              <p class="text-xs font-medium text-foreground">{ex.label}</p>
              <p class="mt-0.5 font-mono text-[10px] text-muted-foreground">{ex.platform}</p>
            </div>
            <span class="rounded-sm border border-border/40 px-2 py-0.5 font-mono text-[10px] text-muted-foreground">{ex.tagText}</span>
          </div>

          <div class="grid grid-cols-1 divide-y divide-border/40 md:grid-cols-2 md:divide-x md:divide-y-0">
            <div class="p-5">
              <p class="mb-3 font-mono text-[10px] uppercase tracking-wider text-muted-foreground/50">preview</p>
              <div class="space-y-4">
                {ex.messages.map((msg) => (
                  msg.from === "bot" ? (
                    <div class="flex gap-3">
                      <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-sm bg-primary/10 text-xs ring-1 ring-primary/15">
                        🤖
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="mb-1.5 font-mono text-[10px] text-muted-foreground">
                          {msg.name}
                          <span class="ml-1 text-primary/60">[APP]</span>
                          <span class="ml-1">{msg.time}</span>
                        </p>
                        <div class="rounded-sm border border-border/40 bg-surface-2 px-3.5 py-2.5">
                          {msg.lines?.map((line) => (
                            <>
                              {line.type === "text" && <p class="text-xs text-foreground">{line.value}</p>}
                              {line.type === "divider" && <div class="my-2 border-t border-border/40" />}
                              {line.type === "group" && (
                                <div class="mb-2">
                                  <p class="mb-1 font-mono text-[9px] uppercase tracking-wider text-muted-foreground/70">{line.label}</p>
                                  <ul class="space-y-0.5">
                                    {line.items?.map((item) => (
                                      <li class="flex items-start gap-1.5 text-xs text-foreground">
                                        <span class="mt-0.5 shrink-0 text-primary">›</span>
                                        <span>{item}</span>
                                      </li>
                                    ))}
                                  </ul>
                                </div>
                              )}
                              {line.type === "action" && (
                                <div class="flex items-center gap-2 py-0.5 text-xs">
                                  <span>{line.icon}</span>
                                  <span class="font-medium text-muted-foreground">{line.label}</span>
                                  <span class="text-foreground">{line.value}</span>
                                </div>
                              )}
                              {line.type === "link" && (
                                <div class="flex items-start gap-2 py-0.5 text-xs">
                                  <span>{line.icon}</span>
                                  <span class="font-medium shrink-0 text-muted-foreground">{line.label}</span>
                                  <span class="text-foreground">{line.value}</span>
                                </div>
                              )}
                              {line.type === "footer" && (
                                <p class="mt-2 border-t border-border/30 pt-1.5 font-mono text-[9px] text-muted-foreground/60">{line.value}</p>
                              )}
                            </>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : (
                    <div class={`flex gap-3 ${msg.name === "you" ? "flex-row-reverse" : ""}`}>
                      <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-sm text-[10px] font-bold ${avatarColors[msg.color]}`}>
                        {msg.avatar}
                      </div>
                      <div class={msg.name === "you" ? "text-right" : ""}>
                        <p class={`mb-1.5 font-mono text-[10px] text-muted-foreground ${msg.name === "you" ? "text-right" : ""}`}>
                          {msg.name}
                          <span class="ml-1">{msg.time}</span>
                        </p>
                        <div class={`inline-block rounded-sm px-3.5 py-2 text-xs ${msg.name === "you" ? "rounded-tr-none bg-primary/10 border border-primary/15" : "rounded-tl-none border border-border/40 bg-surface-2"}`}>
                          <p class="text-foreground">{msg.text}</p>
                        </div>
                      </div>
                    </div>
                  )
                ))}
              </div>
            </div>

            <div class="p-5">
              <p class="mb-3 font-mono text-[10px] uppercase tracking-wider text-muted-foreground/50">{ex.tabLabel}</p>
              <div class="code-block text-xs leading-relaxed">
                <pre><code set:html={ex.config} /></pre>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const pcTabs = document.querySelectorAll<HTMLElement>("[data-example-idx]");
  const panels = document.querySelectorAll(".example-panel");

  for (const tab of pcTabs) {
    tab.addEventListener("click", () => {
      const idx = Number(tab.dataset.exampleIdx);
      for (const t of pcTabs) {
        t.removeAttribute("data-active");
      }
      tab.setAttribute("data-active", "");
      for (const p of panels) {
        p.classList.add("hidden");
      }
      panels[idx]?.classList.remove("hidden");
    });
  }
</script>
