---
import { siDiscord, siSlack } from "simple-icons";

const examples = [
  {
    id: "sprint-recap",
    tabLabel: "sprint_standup.ts",
    tabIcon: siSlack,
    emoji: "😅",
    label: "The sprint stand-up nobody prepared for",
