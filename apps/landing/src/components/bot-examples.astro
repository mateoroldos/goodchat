---

<section id="examples" class="relative overflow-hidden px-6 py-24">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute left-1/2 top-1/2 h-[700px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.04]"
      style="background: radial-gradient(ellipse, oklch(0.65 0.22 62) 0%, transparent 70%);"
    ></div>
  </div>

  <div class="relative mx-auto max-w-5xl">
    <!-- Section header -->
    <div class="reveal mb-20 text-center">
      <p
        class="mb-3 text-sm font-medium uppercase tracking-widest text-primary"
      >
        Real world
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Situations your team<br class="hidden sm:block">
        actually runs into
      </h2>
      <p class="mt-4 mx-auto max-w-lg text-muted-foreground">
        Click
        <span
          class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-xs text-primary"
          >Config</span
        >
        on any example to see the code that powers it.
      </p>
    </div>

    <!-- Examples: stacked vertically for readability -->
    <div class="space-y-8">
      {examples.map((ex, i) => (
        <div
          class="reveal example-card rounded-3xl border border-white/6 bg-surface-1 overflow-hidden"
          style={`--reveal-delay: ${i * 120}ms`}
          data-example={ex.id}
        >
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-white/6 px-6 py-4">
            <div class="flex items-center gap-3">
              <span class="text-xl">{ex.emoji}</span>
              <div>
                <p class="text-sm font-semibold text-foreground">{ex.label}</p>
                <div class="mt-0.5 flex items-center gap-1.5">
                  <span set:html={platformIcons[ex.platform]} />
                  <span class="text-xs text-muted-foreground">{ex.platformLabel}</span>
                </div>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <span
                class="rounded-full px-2.5 py-1 text-[11px] font-medium"
                style={`background: ${ex.tagBg}; color: ${ex.tagColor};`}
              >{ex.tagText}</span>

              <div class="flex items-center rounded-lg border border-white/8 bg-surface-2 p-0.5">
                <button
                  aria-label="Show chat view"
                  class="tab-btn tab-active rounded-md px-3 py-1.5 text-xs font-medium transition-all"
                  data-view="chat"
                  type="button"
                >
                  💬 Chat
                </button>
                <button
                  aria-label="Show config view"
                  class="tab-btn rounded-md px-3 py-1.5 text-xs font-medium transition-all"
                  data-view="config"
                  type="button"
                >
                  {"</>"}  Config
                </button>
              </div>
            </div>
          </div>
          <div class="view-panel chat-panel p-6">
            <div class="space-y-4 max-w-xl mx-auto">
              {ex.messages.map((msg) => (
                msg.from === "bot" ? (
                  <div class="flex gap-3">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-sm ring-1 ring-primary/20">
                      🤖
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="mb-1.5 text-xs font-medium text-foreground">
                        {msg.name}
                        <span class="ml-1 rounded bg-primary/10 px-1.5 py-0.5 text-[10px] text-primary">APP</span>
                        <span class="ml-1 text-muted-foreground font-normal">{msg.time}</span>
                      </p>
                      <div class="rounded-2xl rounded-tl-sm border border-white/6 bg-surface-2 px-4 py-3">
                        {msg.lines?.map((line) => (
                          <>
                            {line.type === "text" && <p class="text-sm text-foreground">{line.value}</p>}
                            {line.type === "divider" && <div class="my-2.5 border-t border-white/6" />}
                            {line.type === "group" && (
                              <div class="mb-2">
                                <p class="mb-1 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">{line.label}</p>
                                <ul class="space-y-1">
                                  {line.items?.map((item) => (
                                    <li class="flex items-start gap-2 text-xs text-foreground">
                                      <span class="mt-0.5 shrink-0 text-primary">›</span>
                                      <span>{item}</span>
                                    </li>
                                  ))}
                                </ul>
                              </div>
                            )}
                            {line.type === "action" && (
                              <div class="flex items-center gap-2 py-0.5 text-xs">
                                <span>{line.icon}</span>
                                <span class="font-medium text-muted-foreground">{line.label}</span>
                                <span class="text-foreground">{line.value}</span>
                              </div>
                            )}
                            {line.type === "link" && (
                              <div class="flex items-start gap-2 py-0.5 text-xs">
                                <span>{line.icon}</span>
                                <span class="font-medium shrink-0 text-muted-foreground">{line.label}</span>
                                <span class="text-foreground">{line.value}</span>
                              </div>
                            )}
                            {line.type === "footer" && (
                              <p class="mt-2.5 border-t border-white/5 pt-2 text-[10px] text-muted-foreground/70">{line.value}</p>
                            )}
                          </>
                        ))}
                      </div>
                    </div>
                  </div>
                ) : (
                  <div class={`flex gap-3 ${msg.name === "you" ? "flex-row-reverse" : ""}`}>
                    <div class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-bold ${avatarColors[msg.color]}`}>
                      {msg.avatar}
                    </div>
                    <div class={msg.name === "you" ? "text-right" : ""}>
                      <p class={`mb-1.5 text-xs font-medium text-foreground ${msg.name === "you" ? "text-right" : ""}`}>
                        {msg.name}
                        <span class="ml-1 text-muted-foreground font-normal">{msg.time}</span>
                      </p>
                      <div class={`inline-block rounded-2xl px-4 py-2.5 text-sm ${msg.name === "you" ? "rounded-tr-sm bg-primary/15 border border-primary/15" : "rounded-tl-sm border border-white/6 bg-surface-2"}`}>
                        <p class="text-foreground">{msg.text}</p>
                      </div>
                    </div>
                  </div>
                )
              ))}
            </div>
          </div>
          <div class="view-panel config-panel hidden p-6">
            <div class="code-block text-sm leading-relaxed">
              <pre><code set:html={ex.config} /></pre>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Tab toggle */
  .tab-btn {
    color: oklch(0.62 0.04 56);
  }
  .tab-active {
    color: oklch(0.84 0.175 74);
    background: oklch(0.78 0.185 70 / 15%);
  }
</style>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll(".reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  for (const el of reveals) {
    observer.observe(el);
  }

  // Tab toggle per card
  const cards = document.querySelectorAll(".example-card");
  for (const card of cards) {
    const tabs = card.querySelectorAll(".tab-btn");
    const chatPanel = card.querySelector(".chat-panel");
    const configPanel = card.querySelector(".config-panel");

    for (const tab of tabs) {
      tab.addEventListener("click", () => {
        const view = (tab as HTMLElement).dataset.view;

        for (const t of tabs) {
          t.classList.remove("tab-active");
        }
        tab.classList.add("tab-active");

        if (view === "chat") {
          chatPanel?.classList.remove("hidden");
          configPanel?.classList.add("hidden");
        } else {
          chatPanel?.classList.add("hidden");
          configPanel?.classList.remove("hidden");
        }
      });
    }
  }
</script>
