        text: "PagerDuty triggered. Nobody's acknowledging.",
      },
      {
        from: "bot",
        name: "incident-bot",
        time: "3:15 AM",
        lines: [
          { type: "text", value: "Incident detected. Taking action now." },
          { type: "divider" },
          {
            type: "action",
            icon: "🎫",
            label: "Created",
