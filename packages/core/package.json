{
  "name": "@goodchat/core",
  "version": "0.0.6",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc -b",
    "prepack": "bunx turbo build --filter=web --filter=@goodchat/core && bun ../../scripts/copy-web-assets.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.41",
    "@chat-adapter/discord": "^4.20.0",
    "@chat-adapter/gchat": "^4.20.0",
    "@chat-adapter/slack": "^4.20.0",
    "@chat-adapter/state-memory": "^4.20.0",
    "@chat-adapter/state-redis": "^4.20.0",
    "@chat-adapter/teams": "^4.20.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.7",
    "@goodchat/contracts": "workspace:*",
    "@t3-oss/env-core": "^0.13.1",
    "ai": "^6.0.116",
    "better-result": "^2.7.0",
    "chat": "^4.20.0",
    "elysia": "^1.4.28",
    "zod": "catalog:"
  },
  "devDependencies": {
    "tsdown": "^0.21.4"
  }
}
