{
  "name": "@goodchat/storage",
  "version": "0.0.15",
  "private": false,
  "type": "module",
  "files": [
    "dist/**"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc -b",
    "test:sqlite": "bun test tests/sqlite",
    "test:postgres": "vitest run tests/postgres",
    "test:mysql": "vitest run tests/mysql"
  },
  "exports": {
    "./sqlite": {
      "types": "./dist/sqlite.d.mts",
      "import": "./dist/sqlite.mjs"
    },
    "./postgres": {
      "types": "./dist/postgres.d.mts",
      "import": "./dist/postgres.mjs"
    },
    "./mysql": {
      "types": "./dist/mysql.d.mts",
      "import": "./dist/mysql.mjs"
    },
    "./schema/sqlite": {
      "types": "./dist/schema/sqlite.d.mts",
      "import": "./dist/schema/sqlite.mjs",
      "default": "./dist/schema/sqlite.mjs"
    },
    "./schema/postgres": {
      "types": "./dist/schema/postgres.d.mts",
      "import": "./dist/schema/postgres.mjs"
    },
    "./schema/mysql": {
      "types": "./dist/schema/mysql.d.mts",
      "import": "./dist/schema/mysql.mjs"
    },
    "./schema/auth/sqlite": {
      "types": "./dist/schema/auth/sqlite.d.mts",
      "import": "./dist/schema/auth/sqlite.mjs",
      "default": "./dist/schema/auth/sqlite.mjs"
    },
    "./schema/auth/postgres": {
      "types": "./dist/schema/auth/postgres.d.mts",
      "import": "./dist/schema/auth/postgres.mjs"
    },
    "./schema/auth/mysql": {
      "types": "./dist/schema/auth/mysql.d.mts",
      "import": "./dist/schema/auth/mysql.mjs"
    }
  },
  "dependencies": {
    "@goodchat/contracts": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/postgres": "^0.10.0",
    "better-auth": "1.3.4",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@goodchat/typescript-config": "workspace:*",
    "@types/pg": "^8.20.0",
    "nanoid": "^5.1.9",
    "tsdown": "^0.21.4",
    "vitest": "^4.1.0"
  }
}
