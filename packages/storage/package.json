{
  "name": "@goodchat/storage",
  "version": "0.0.20",
  "private": false,
  "type": "module",
  "files": [
    "dist/**"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check:core-schema-sync": "bun scripts/check-core-schema-sync.mjs",
    "gen:core-schema": "bun scripts/generate-core-schema.mjs",
    "dev": "tsdown --watch",
    "check-types": "tsc -b",
    "test:sqlite": "bun test tests/sqlite",
    "test:postgres": "vitest run tests/postgres",
    "test:mysql": "vitest run tests/mysql"
  },
  "exports": {
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.mjs"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.mjs"
    },
    "./mysql": {
      "types": "./dist/mysql.d.ts",
      "import": "./dist/mysql.mjs"
    },
    "./internal-schema/shared": {
      "types": "./dist/internal-schema/shared.d.ts",
      "import": "./dist/internal-schema/shared.mjs"
    },
    "./scaffold/schema-foundation": {
      "types": "./dist/scaffold/schema-foundation.d.ts",
      "import": "./dist/scaffold/schema-foundation.mjs"
    },
    "./scaffold/db-schema-artifacts": {
      "types": "./dist/scaffold/db-schema-artifacts.d.ts",
      "import": "./dist/scaffold/db-schema-artifacts.mjs"
    }
  },
  "dependencies": {
    "@goodchat/contracts": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/postgres": "^0.10.0",
    "better-auth": "1.3.4",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@goodchat/typescript-config": "workspace:*",
    "@types/pg": "^8.20.0",
    "nanoid": "^5.1.9",
    "tsdown": "^0.21.4",
    "vitest": "^4.1.0"
  }
}
