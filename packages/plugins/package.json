{
  "name": "@goodchat/plugins",
  "version": "0.0.4",
  "private": false,
  "type": "module",
  "main": "./dist/linear.cjs",
  "module": "./dist/linear.mjs",
  "types": "./dist/linear.d.mts",
  "files": [
    "dist/**"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc -b"
  },
  "exports": {
    "./linear": {
      "types": "./dist/linear.d.mts",
      "import": "./dist/linear.mjs",
      "require": "./dist/linear.cjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@goodchat/contracts": "workspace:*",
    "ai": "^6.0.116",
    "zod": "catalog:"
  },
  "devDependencies": {
    "tsdown": "^0.21.4"
  }
}
